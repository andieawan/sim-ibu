# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---- Server Configuration ----
# PORT: The port the server should listen on in development or production.
# HOST: The network host interface, usually 0.0.0.0 for containerized environments.
PORT=3000
HOST=0.0.0.0

# ---- Database Configuration ----
# DB_TYPE: 'sqlite' (default), 'postgres', or 'mysql'
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
DB_NAME=sim-ibu_db
DB_SSL=false

# DEFAULT CREDENTIALS FOR SEEDING
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_GURU_PASSWORD=guru123
DEFAULT_ORTU_PASSWORD=ortu123

# ---- Cookie Authentication ----
COOKIE_PASSWORD="a_very_long_and_secure_random_string_of_at_least_32_characters"

# ---- Application Mode ----
# APP_ENV: 'dev' or 'pub' (default: 'dev')
# If set to 'pub', demo account options on the login page will be hidden.
APP_ENV=dev


